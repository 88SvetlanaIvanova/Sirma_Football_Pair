					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"packages": {},
				"requests": {},
				"exec": [
					"\r",
					"{\r",
					"  \"info\": {\r",
					"    \"name\": \"Santa Workshop - Gift API\",\r",
					"    \"_postman_id\": \"0f6c7e3a-8e0b-4f6c-9be3-abc123456789\",\r",
					"    \"description\": \"End-to-end tests for Gift endpoints\",\r",
					"    \"schema\": \"https://schema.getpostman.com/json/collection/v2.1.0/collection.json\"\r",
					"  },\r",
					"  \"item\": [\r",
					"    {\r",
					"      \"name\": \"01 - Create Gift (POST /api/gifts)\",\r",
					"      \"request\": {\r",
					"        \"method\": \"POST\",\r",
					"        \"header\": [\r",
					"          { \"key\": \"Content-Type\", \"value\": \"application/json\" },\r",
					"          { \"key\": \"Accept\", \"value\": \"application/json\" }\r",
					"        ],\r",
					"        \"url\": { \"raw\": \"{{baseUrl}}/api/gifts\", \"host\": [\"{{baseUrl}}\"], \"path\": [\"api\",\"gifts\"] },\r",
					"        \"body\": {\r",
					"          \"mode\": \"raw\",\r",
					"          \"raw\": \"{\\n  \\\"name\\\": \\\"Lego City Fire Truck\\\",\\n  \\\"category\\\": \\\"TOY\\\",\\n  \\\"targetAge\\\": 7\\n}\"\r",
					"        }\r",
					"      },\r",
					"      \"event\": [\r",
					"        {\r",
					"          \"listen\": \"test\",\r",
					"          \"script\": {\r",
					"            \"exec\": [\r",
					"              \"pm.test('Status is 201 Created', () => pm.response.code === 201);\",\r",
					"              \"\",\r",
					"              \"const json = pm.response.json();\",\r",
					"              \"pm.test('Response matches GiftResponse schema', () => {\",\r",
					"              \"  pm.expect(json).to.have.property('id');\",\r",
					"              \"  pm.expect(json).to.have.property('name');\",\r",
					"              \"  pm.expect(json).to.have.property('category');\",\r",
					"              \"  pm.expect(json).to.have.property('isWrapped', false);\",\r",
					"              \"  pm.expect(json).to.have.property('status', 'PENDING');\",\r",
					"              \"  pm.expect(json).to.have.property('createdAt');\",\r",
					"              \"});\",\r",
					"              \"\",\r",
					"              \"pm.environment.set('giftId', json.id);\",\r",
					"              \"pm.environment.set('createdGiftName', json.name);\",\r",
					"              \"pm.test('createdAt is ISO date-time', () => {\",\r",
					"              \"  const d = new Date(json.createdAt);\",\r",
					"              \"  pm.expect(!isNaN(d.valueOf())).to.be.true;\",\r",
					"              \"});\"\r",
					"            ],\r",
					"            \"type\": \"text/javascript\"\r",
					"          }\r",
					"        }\r",
					"      ]\r",
					"    },\r",
					"    {\r",
					"      \"name\": \"02 - List Gifts (GET /api/gifts)\",\r",
					"      \"request\": {\r",
					"        \"method\": \"GET\",\r",
					"        \"header\": [\r",
					"          { \"key\": \"Accept\", \"value\": \"application/json\" }\r",
					"        ],\r",
					"        \"url\": {\r",
					"          \"raw\": \"{{baseUrl}}/api/gifts?page=0&size=10&sort=createdAt\",\r",
					"          \"host\": [\"{{baseUrl}}\"],\r",
					"          \"path\": [\"api\",\"gifts\"],\r",
					"          \"query\": [\r",
					"            { \"key\": \"page\", \"value\": \"0\" },\r",
					"            { \"key\": \"size\", \"value\": \"10\" },\r",
					"            { \"key\": \"sort\", \"value\": \"createdAt\" }\r",
					"          ]\r",
					"        }\r",
					"      },\r",
					"      \"event\": [\r",
					"        {\r",
					"          \"listen\": \"test\",\r",
					"          \"script\": {\r",
					"            \"exec\": [\r",
					"              \"pm.test('Status is 200', () => pm.response.code === 200);\",\r",
					"              \"const page = pm.response.json();\",\r",
					"              \"pm.test('Page content exists', () => pm.expect(page.content).to.be.an('array'));\",\r",
					"              \"pm.test('Newest first (createdAt DESC default)', () => {\",\r",
					"              \"  if (page.content.length > 1) {\",\r",
					"              \"    const first = new Date(page.content[0].createdAt).valueOf();\",\r",
					"              \"    const second = new Date(page.content[1].createdAt).valueOf();\",\r",
					"              \"    pm.expect(first >= second).to.be.true;\",\r",
					"              \"  }\",\r",
					"              \"});\"\r",
					"            ],\r",
					"            \"type\": \"text/javascript\"\r",
					"          }\r",
					"        }\r",
					"      ]\r",
					"    },\r",
					"    {\r",
					"      \"name\": \"03 - Filter by status/category/wrapped\",\r",
					"      \"request\": {\r",
					"        \"method\": \"GET\",\r",
					"        \"header\": [{ \"key\": \"Accept\", \"value\": \"application/json\" }],\r",
					"        \"url\": {\r",
					"          \"raw\": \"{{baseUrl}}/api/gifts?status=PENDING&category=TOY&wrapped=false&page=0&size=5&sort=name\",\r",
					"          \"host\": [\"{{baseUrl}}\"],\r",
					"          \"path\": [\"api\",\"gifts\"],\r",
					"          \"query\": [\r",
					"            { \"key\": \"status\", \"value\": \"PENDING\" },\r",
					"            { \"key\": \"category\", \"value\": \"TOY\" },\r",
					"            { \"key\": \"wrapped\", \"value\": \"false\" },\r",
					"            { \"key\": \"page\", \"value\": \"0\" },\r",
					"            { \"key\": \"size\", \"value\": \"5\" },\r",
					"            { \"key\": \"sort\", \"value\": \"name\" }\r",
					"          ]\r",
					"        }\r",
					"      },\r",
					"      \"event\": [\r",
					"        {\r",
					"          \"listen\": \"test\",\r",
					"          \"script\": {\r",
					"            \"exec\": [\r",
					"              \"pm.test('Status is 200', () => pm.response.code === 200);\",\r",
					"              \"const page = pm.response.json();\",\r",
					"              \"pm.test('All results match filters', () => {\",\r",
					"              \"  page.content.forEach(g => {\",\r",
					"              \"    pm.expect(g.status).to.eql('PENDING');\",\r",
					"              \"    pm.expect(g.category).to.eql('TOY');\",\r",
					"              \"    pm.expect(g.isWrapped).to.eql(false);\",\r",
					"              \"  });\",\r",
					"              \"});\",\r",
					"              \"pm.test('Sorted ascending by name when sort=name', () => {\",\r",
					"              \"  const names = page.content.map(g => g.name);\",\r",
					"              \"  const sorted = [...names].sort((a,b) => a.localeCompare(b));\",\r",
					"              \"  pm.expect(names.join('|')).to.eql(sorted.join('|'));\",\r",
					"              \"});\"\r",
					"            ],\r",
					"            \"type\": \"text/javascript\"\r",
					"          }\r",
					"        }\r",
					"      ]\r",
					"    },\r",
					"    {\r",
					"      \"name\": \"04 - Get Gift by ID (GET /api/gifts/{{giftId}})\",\r",
					"      \"request\": {\r",
					"        \"method\": \"GET\",\r",
					"        \"header\": [{ \"key\": \"Accept\", \"value\": \"application/json\" }],\r",
					"        \"url\": { \"raw\": \"{{baseUrl}}/api/gifts/{{giftId}}\", \"host\": [\"{{baseUrl}}\"], \"path\": [\"api\",\"gifts\",\"{{giftId}}\"] }\r",
					"      },\r",
					"      \"event\": [\r",
					"        {\r",
					"          \"listen\": \"test\",\r",
					"          \"script\": {\r",
					"            \"exec\": [\r",
					"              \"pm.test('Status is 200', () => pm.response.code === 200);\",\r",
					"              \"const g = pm.response.json();\",\r",
					"              \"pm.test('ID matches saved giftId', () => pm.expect(g.id).to.eql(Number(pm.environment.get('giftId'))));\",\r",
					"              \"pm.test('Name matches created name', () => pm.expect(g.name).to.eql(pm.environment.get('createdGiftName')));\"\r",
					"            ],\r",
					"            \"type\": \"text/javascript\"\r",
					"          }\r",
					"        }\r",
					"      ]\r",
					"    },\r",
					"    {\r",
					"      \"name\": \"05 - Wrap Gift (PATCH /api/gifts/{{giftId}}/wrap)\",\r",
					"      \"request\": {\r",
					"        \"method\": \"PATCH\",\r",
					"        \"header\": [\r",
					"          { \"key\": \"Accept\", \"value\": \"application/json\" }\r",
					"        ],\r",
					"        \"url\": { \"raw\": \"{{baseUrl}}/api/gifts/{{giftId}}/wrap\", \"host\": [\"{{baseUrl}}\"], \"path\": [\"api\",\"gifts\",\"{{giftId}}\",\"wrap\"] }\r",
					"      },\r",
					"      \"event\": [\r",
					"        {\r",
					"          \"listen\": \"test\",\r",
					"          \"script\": {\r",
					"            \"exec\": [\r",
					"              \"pm.test('Status is 200', () => pm.response.code === 200);\",\r",
					"              \"const g = pm.response.json();\",\r",
					"              \"pm.test('isWrapped is true after wrap', () => pm.expect(g.isWrapped).to.eql(true));\",\r",
					"              \"// Idempotency check: calling wrap again should keep true (server returns updated gift with true)\",\r",
					"              \"pm.environment.set('wrappedCheckId', g.id);\"\r",
					"            ],\r",
					"            \"type\": \"text/javascript\"\r",
					"          }\r",
					"        }\r",
					"      ]\r",
					"    },\r",
					"    {\r",
					"      \"name\": \"05b - Wrap Gift again (idempotency)\",\r",
					"      \"request\": {\r",
